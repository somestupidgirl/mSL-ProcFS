[submodule "MacKernelSDK"]
	path = lib/MacKernelSDK
	url = git@github.com:acidanthera/MacKernelSDK.git
[submodule "lib/libutil"]
	path = lib/libutil
	url = https://github.com/apple-oss-distributions/libutil.git
[submodule "lib/xnu"]
	path = lib/xnu
	url = https://github.com/apple-oss-distributions/xnu.git
        ignore = dirty
[submodule "lib/libsbuf"]
	path = lib/libsbuf
	url = https://github.com/somestupidgirl/libsbuf.git
[submodule "lib/libbsdmalloc"]
	path = lib/libbsdmalloc
	url = https://github.com/somestupidgirl/libbsdmalloc.git
[submodule "lib/libcpuft"]
	path = lib/libcpuft
	url = https://github.com/somestupidgirl/libcpuft
