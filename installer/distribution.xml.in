<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>ProcFS __KEXTVERSION__</title>
    <organization>com.beako.filesystems</organization>
    <options customize="never" require-scripts="true"
             hostArchitectures="arm64,x86_64" rootVolumeOnly="true"/>

    <welcome    file="welcome.html"    mime-type="text/html"/>
    <license    file="LICENSE"         mime-type="text/plain"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <choices-outline>
        <line choice="default">
            <line choice="procfs"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="procfs" title="ProcFS" visible="false">
        <pkg-ref id="com.beako.filesystems.procfs.pkg"/>
    </choice>

    <pkg-ref id="com.beako.filesystems.procfs.pkg" version="__KEXTVERSION__"
             onConclusion="none">procfs-component.pkg</pkg-ref>
</installer-gui-script>
